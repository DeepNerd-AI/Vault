#!/usr/bin/env bash

set -euxo pipefail

# Help info function
help_info() {
  echo "
Usage: ${0##*/} [options]
Build a release .deb package for Linux.

Options:
  -h, --help     Display this help and exit.
  "
}

# Parse all arguments
while [[ $# -gt 0 ]]; do
    case $1 in
        -h|--help)
            help_info
            exit 0
            ;;
        *)
            echo "Error: Unexpected argument: $1" >&2
            help_info
            exit 1
            ;;
    esac
done

# Ensure dpkg-deb is available
if ! command -v dpkg-deb >/dev/null 2>&1; then
    echo "Error: dpkg-deb is required to build deb packages." >&2
    exit 1
fi

channel=$(<crates/zed/RELEASE_CHANNEL)
target_dir="${CARGO_TARGET_DIR:-target}"
version="$(script/get-crate-version vault)"

suffix=""
if [ "$channel" != "stable" ]; then
  suffix="-$channel"
fi

arch="$(uname -m)"
deb_arch="amd64"
case "$arch" in
    x86_64)
        deb_arch="amd64"
        ;;
    aarch64)
        deb_arch="arm64"
        ;;
    *)
        deb_arch="$arch"
        ;;
esac

archive="vault-linux-${arch}.tar.gz"
tarball_path="${target_dir}/release/${archive}"

# Build the bundle if it doesn't exist
# We force script/bundle-linux to run if target file is not present
if [ ! -f "${tarball_path}" ]; then
    echo "Bundle tarball not found at ${tarball_path}. Building now..."
    script/bundle-linux
fi

# Create a temporary directory for deb building
temp_deb_dir=$(mktemp -d)
trap 'rm -rf "${temp_deb_dir}"' EXIT

# Determine the app ID, binary name, and display name
if [[ "$channel" == "preview" ]]; then
    app_name="Vault Preview"
    app_id="editor.deepnerd.tech-Preview"
    bin_name="vault-preview"
    legacy_bin_name="zed-preview"
elif [[ "$channel" == "nightly" ]]; then
    app_name="Vault Nightly"
    app_id="editor.deepnerd.tech-Nightly"
    bin_name="vault-nightly"
    legacy_bin_name="zed-nightly"
elif [[ "$channel" == "dev" ]]; then
    app_name="Vault Dev"
    app_id="editor.deepnerd.tech-Dev"
    bin_name="vault-dev"
    legacy_bin_name="zed-dev"
else
    app_name="Vault"
    app_id="editor.deepnerd.tech"
    bin_name="vault"
    legacy_bin_name="zed"
fi

# Reconstruct installation tree in the debian build directory
install_prefix="${temp_deb_dir}/usr/lib/vault${suffix}"
mkdir -p "${install_prefix}"

# Extract the linux tar.gz directly into our build prefix
tar -xzf "${tarball_path}" -C "${temp_deb_dir}/usr/lib/"
# The archive contains a single directory: vault.app (or vault-preview.app etc)
mv "${temp_deb_dir}/usr/lib/vault${suffix}.app/"* "${install_prefix}/"
rm -rf "${temp_deb_dir}/usr/lib/vault${suffix}.app"

# Create /usr/bin symlinks
mkdir -p "${temp_deb_dir}/usr/bin"
ln -sf "/usr/lib/vault${suffix}/bin/vault" "${temp_deb_dir}/usr/bin/${bin_name}"
ln -sf "/usr/lib/vault${suffix}/bin/vault" "${temp_deb_dir}/usr/bin/${legacy_bin_name}"

# Copy and structure icons into /usr/share/icons
mkdir -p "${temp_deb_dir}/usr/share/icons/hicolor/512x512/apps"
cp "${install_prefix}/share/icons/hicolor/512x512/apps/vault.png" "${temp_deb_dir}/usr/share/icons/hicolor/512x512/apps/${bin_name}.png"
mkdir -p "${temp_deb_dir}/usr/share/icons/hicolor/1024x1024/apps"
cp "${install_prefix}/share/icons/hicolor/1024x1024/apps/vault.png" "${temp_deb_dir}/usr/share/icons/hicolor/1024x1024/apps/${bin_name}.png"

# Setup the .desktop file inside /usr/share/applications
mkdir -p "${temp_deb_dir}/usr/share/applications"
cp "${install_prefix}/share/applications/${app_id}.desktop" "${temp_deb_dir}/usr/share/applications/${app_id}.desktop"

# Fix the Exec and Icon entries in the desktop file to point to standard system paths
sed -i "s|Icon=vault|Icon=/usr/share/icons/hicolor/512x512/apps/${bin_name}.png|g" "${temp_deb_dir}/usr/share/applications/${app_id}.desktop"
sed -i "s|Exec=vault|Exec=/usr/bin/${bin_name}|g" "${temp_deb_dir}/usr/share/applications/${app_id}.desktop"
sed -i "s|TryExec=vault|TryExec=/usr/bin/${bin_name}|g" "${temp_deb_dir}/usr/share/applications/${app_id}.desktop"

# Create the control file
mkdir -p "${temp_deb_dir}/DEBIAN"
cat > "${temp_deb_dir}/DEBIAN/control" <<EOF
Package: ${bin_name}
Version: ${version}
Section: devel
Priority: optional
Architecture: ${deb_arch}
Maintainer: DeepNerd <info@deepnerd.tech>
Depends: libc6, libgcc-s1, libfontconfig1, libx11-xcb1, libxcb-dri3-0, libxcb-randr0, libxkbcommon-x11-0, libxkbcommon0, libdbus-1-3, libssl3 | libssl1.1
Description: ${app_name} IDE - high-performance, multiplayer code editor.
EOF

# Build the Debian package
output_deb="${target_dir}/release/${bin_name}-linux-${arch}.deb"
dpkg-deb --build "${temp_deb_dir}" "${output_deb}"

echo "Debian package successfully built at: ${output_deb}"
